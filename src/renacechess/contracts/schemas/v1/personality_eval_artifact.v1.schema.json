{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "personality_eval_artifact.v1.schema.json",
  "title": "Personality Evaluation Artifact v1",
  "description": "Schema for offline personality evaluation artifacts. Captures divergence metrics, envelope utilization, and structural attribution for personality comparisons (M18).",
  "type": "object",
  "required": [
    "schemaVersion",
    "createdAt",
    "personalityId",
    "baselineId",
    "configHash",
    "determinismHash",
    "divergenceMetrics",
    "envelopeUtilization",
    "policyStats"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "personality_eval_artifact.v1",
      "description": "Schema version identifier"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of artifact creation"
    },
    "personalityId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Personality being evaluated (e.g., 'style.pawn_clamp.v1')"
    },
    "baselineId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Baseline personality for comparison (e.g., 'control.neutral_baseline.v1')"
    },
    "configHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of personality configuration used"
    },
    "determinismHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash for determinism verification (hash of all inputs + outputs)"
    },
    "fixtureId": {
      "type": "string",
      "description": "Identifier of the fixture used (for traceability)"
    },
    "divergenceMetrics": {
      "$ref": "#/$defs/DivergenceMetrics",
      "description": "Divergence metrics between personality and baseline"
    },
    "envelopeUtilization": {
      "$ref": "#/$defs/EnvelopeUtilization",
      "description": "Safety envelope utilization statistics"
    },
    "structuralAttribution": {
      "$ref": "#/$defs/StructuralAttribution",
      "description": "Attribution of divergence to structural features (optional)"
    },
    "policyStats": {
      "$ref": "#/$defs/PolicyStats",
      "description": "Policy distribution statistics"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "DivergenceMetrics": {
      "type": "object",
      "description": "Divergence metrics between personality output and baseline",
      "required": ["klDivergence", "totalVariation"],
      "properties": {
        "klDivergence": {
          "type": "number",
          "minimum": 0.0,
          "description": "Kullback-Leibler divergence from baseline (bits)"
        },
        "totalVariation": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Total Variation distance [0.0, 1.0]"
        },
        "jensenShannon": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Jensen-Shannon divergence [0.0, 1.0] (optional)"
        },
        "maxProbabilityDelta": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Maximum probability shift for any move"
        },
        "meanProbabilityDelta": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Mean absolute probability shift across moves"
        }
      },
      "additionalProperties": false
    },
    "EnvelopeUtilization": {
      "type": "object",
      "description": "Safety envelope utilization statistics",
      "required": ["deltaPMaxUsedPct", "topKBinding"],
      "properties": {
        "deltaPMaxUsedPct": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 100.0,
          "description": "Percentage of delta_p_max utilized [0.0, 100.0]"
        },
        "deltaPMaxUsedAbs": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Absolute delta_p_max utilization"
        },
        "deltaPMaxLimit": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "The delta_p_max limit from constraints"
        },
        "topKBinding": {
          "type": "boolean",
          "description": "Whether top_k constraint was binding (moves were truncated)"
        },
        "topKLimit": {
          "type": "integer",
          "minimum": 1,
          "description": "The top_k limit from constraints"
        },
        "movesConsidered": {
          "type": "integer",
          "minimum": 0,
          "description": "Actual number of moves considered"
        },
        "entropyInBounds": {
          "type": "boolean",
          "description": "Whether output entropy is within bounds"
        },
        "outputEntropy": {
          "type": "number",
          "minimum": 0.0,
          "description": "Actual output entropy"
        }
      },
      "additionalProperties": false
    },
    "StructuralAttribution": {
      "type": "object",
      "description": "Attribution of divergence to structural features",
      "properties": {
        "styleScoreComponents": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ComponentStats"
          },
          "description": "Per-component style score statistics"
        },
        "featureDeltas": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ComponentStats"
          },
          "description": "Per-feature delta statistics"
        },
        "correlationProxy": {
          "type": "number",
          "minimum": -1.0,
          "maximum": 1.0,
          "description": "Normalized dot product between style scores and divergence (proxy for correlation)"
        }
      },
      "additionalProperties": false
    },
    "ComponentStats": {
      "type": "object",
      "description": "Statistics for a single component or feature",
      "required": ["mean"],
      "properties": {
        "mean": {
          "type": "number",
          "description": "Mean value"
        },
        "min": {
          "type": "number",
          "description": "Minimum value"
        },
        "max": {
          "type": "number",
          "description": "Maximum value"
        }
      },
      "additionalProperties": false
    },
    "PolicyStats": {
      "type": "object",
      "description": "Policy distribution statistics",
      "required": ["baseEntropy", "outputEntropy", "moveCount"],
      "properties": {
        "baseEntropy": {
          "type": "number",
          "minimum": 0.0,
          "description": "Entropy of base policy"
        },
        "outputEntropy": {
          "type": "number",
          "minimum": 0.0,
          "description": "Entropy of output policy"
        },
        "entropyDelta": {
          "type": "number",
          "description": "Change in entropy (output - base)"
        },
        "moveCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of moves in policy"
        },
        "baseTopGap": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Top gap in base policy"
        },
        "outputTopGap": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Top gap in output policy"
        }
      },
      "additionalProperties": false
    }
  }
}

