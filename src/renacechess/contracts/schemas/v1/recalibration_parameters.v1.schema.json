{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renacechess.dev/schemas/v1/recalibration_parameters.v1.schema.json",
  "title": "RecalibrationParametersV1",
  "description": "Pure parameter artifact containing fitted temperature scaling parameters per Elo bucket (M25). Contains no logic and no metrics, only fitted parameters + provenance.",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "sourceCalibrationMetricsHash",
    "sourceManifestHash",
    "policyId",
    "byEloBucket",
    "determinismHash"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version identifier"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of parameters generation"
    },
    "sourceCalibrationMetricsHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the CalibrationMetricsV1 artifact used for fitting"
    },
    "sourceManifestHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hash of the frozen eval manifest used"
    },
    "policyId": {
      "type": "string",
      "description": "Policy provider identifier used for evaluation"
    },
    "outcomeHeadId": {
      "type": ["string", "null"],
      "description": "Outcome head identifier used (null if using baselines)"
    },
    "byEloBucket": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/RecalibrationBucketParametersV1"
      },
      "description": "Recalibration parameters per Elo bucket"
    },
    "determinismHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash for determinism verification"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "RecalibrationBucketParametersV1": {
      "type": "object",
      "required": [
        "eloBucket",
        "outcomeTemperature",
        "policyTemperature",
        "fitMethod",
        "fitMetric"
      ],
      "properties": {
        "eloBucket": {
          "type": "string",
          "description": "Canonical skill bucket ID (from conditioning.buckets.SkillBucketId)"
        },
        "outcomeTemperature": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 3.0,
          "description": "Fitted temperature for outcome head (W/D/L) recalibration"
        },
        "policyTemperature": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 3.0,
          "description": "Fitted temperature for policy head (move probabilities) recalibration"
        },
        "fitMethod": {
          "type": "string",
          "const": "grid_search",
          "description": "Method used for fitting (M25: grid_search only)"
        },
        "fitMetric": {
          "type": "string",
          "const": "nll",
          "description": "Metric optimized during fitting (M25: NLL only)"
        }
      },
      "additionalProperties": false
    }
  }
}

