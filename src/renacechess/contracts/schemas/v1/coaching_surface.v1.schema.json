{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coaching_surface.v1.schema.json",
  "title": "CoachingSurfaceV1",
  "description": "Coaching surface artifact (M22) — contracted CLI output for auditable coaching exposure. This is a projection of CoachingDraftV1 + CoachingEvaluationV1, not a transformation.",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "coachingText",
    "skillBucket",
    "toneProfile",
    "evaluationSummary",
    "sourceAdviceFactsHash",
    "sourceDeltaFactsHash",
    "coachingDraftHash",
    "coachingEvaluationHash"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "coaching_surface.v1",
      "description": "Schema version identifier"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of surface artifact creation"
    },
    "coachingText": {
      "type": "string",
      "minLength": 1,
      "description": "Generated coaching prose (from CoachingDraftV1.draftText)"
    },
    "skillBucket": {
      "type": "string",
      "description": "Target skill bucket for this coaching"
    },
    "toneProfile": {
      "type": "string",
      "enum": ["neutral", "encouraging", "concise"],
      "description": "Tone profile used for generation"
    },
    "evaluationSummary": {
      "$ref": "#/$defs/CoachingSurfaceEvaluationSummaryV1",
      "description": "Evaluation metrics (always displayed, never hidden)"
    },
    "sourceAdviceFactsHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Determinism hash of source AdviceFactsV1"
    },
    "sourceDeltaFactsHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Determinism hash of source EloBucketDeltaFactsV1 (required in M22)"
    },
    "coachingDraftHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Determinism hash of source CoachingDraftV1"
    },
    "coachingEvaluationHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "Determinism hash of source CoachingEvaluationV1"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "CoachingSurfaceEvaluationSummaryV1": {
      "type": "object",
      "description": "Evaluation summary subset for CLI display",
      "required": [
        "factCoverage",
        "hallucinationRate",
        "bucketAlignment",
        "deltaFaithfulness",
        "verbosityScore",
        "passed"
      ],
      "properties": {
        "factCoverage": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Fraction of salient facts referenced (0.0-1.0)"
        },
        "hallucinationRate": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Fraction of sentences with unsupported claims (0.0-1.0)"
        },
        "bucketAlignment": {
          "type": "boolean",
          "description": "True if language matches target skill bucket"
        },
        "deltaFaithfulness": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Accuracy of Elo delta claims"
        },
        "verbosityScore": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Verbosity score (0.0=too short, 0.5=ideal, 1.0=too long)"
        },
        "passed": {
          "type": "boolean",
          "description": "True if evaluation passed all quality gates"
        },
        "failureReasons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Reasons for failure (empty if passed)"
        }
      },
      "additionalProperties": false
    }
  }
}

