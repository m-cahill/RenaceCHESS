{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Frozen Evaluation Manifest v1",
  "description": "Schema for frozen evaluation manifest (v1) - immutable evaluation set with stratification metadata",
  "type": "object",
  "required": [
    "schemaVersion",
    "createdAt",
    "sourceManifestRef",
    "records",
    "manifestHash"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "sourceManifestRef": {
      "type": "object",
      "required": ["datasetDigest", "manifestPath"],
      "properties": {
        "datasetDigest": {
          "type": "string",
          "description": "SHA-256 hash from source dataset manifest v2 (stable dataset identity)",
          "pattern": "^[a-f0-9]{64}$"
        },
        "manifestPath": {
          "type": "string",
          "description": "Path to source dataset manifest v2"
        }
      },
      "description": "Reference to source dataset manifest v2"
    },
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["recordKey", "shardId", "shardHash"],
        "properties": {
          "recordKey": {
            "type": "string",
            "description": "Record identifier (e.g., 'fen:ply')"
          },
          "shardId": {
            "type": "string",
            "description": "Shard identifier containing this record"
          },
          "shardHash": {
            "type": "string",
            "description": "SHA-256 hash of the shard file",
            "pattern": "^[a-f0-9]{64}$"
          },
          "skillBucketId": {
            "type": ["string", "null"],
            "enum": ["lt_800", "800_999", "1000_1199", "1200_1399", "1400_1599", "1600_1799", "gte_1800", "unknown", null],
            "description": "M06 skill bucket ID for this record (if available)"
          },
          "timeControlClass": {
            "type": ["string", "null"],
            "enum": ["bullet", "blitz", "rapid", "classical", "unknown", null],
            "description": "Time control class for this record (if available)"
          },
          "timePressureBucket": {
            "type": ["string", "null"],
            "enum": ["early", "normal", "low", "trouble", "unknown", null],
            "description": "Time pressure bucket for this record (if available)"
          }
        }
      },
      "description": "Array of record references with conditioning metadata"
    },
    "stratificationTargets": {
      "type": "object",
      "properties": {
        "totalRecords": {
          "type": "integer",
          "minimum": 0,
          "description": "Target total record count"
        },
        "minPerSkillBucket": {
          "type": "integer",
          "minimum": 0,
          "description": "Hard minimum records per skill bucket (if available)"
        }
      },
      "description": "Stratification targets used during selection"
    },
    "countsBySkillBucketId": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Record counts by M06 skill bucket ID (keyed by bucket ID)"
    },
    "countsByTimeControlClass": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Record counts by time control class (keyed by class)"
    },
    "countsByTimePressureBucket": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Record counts by time pressure bucket (keyed by bucket)"
    },
    "coverageShortfalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["axis", "value", "target", "actual"],
        "properties": {
          "axis": {
            "type": "string",
            "enum": ["skillBucketId", "timeControlClass", "timePressureBucket"],
            "description": "Conditioning axis with shortfall"
          },
          "value": {
            "type": "string",
            "description": "Specific bucket/class/value with shortfall"
          },
          "target": {
            "type": "integer",
            "minimum": 0,
            "description": "Target record count"
          },
          "actual": {
            "type": "integer",
            "minimum": 0,
            "description": "Actual record count"
          }
        }
      },
      "description": "Coverage shortfalls (where targets not met)"
    },
    "manifestHash": {
      "type": "string",
      "description": "SHA-256 hash of canonical JSON for this manifest (computed after all other fields)",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

