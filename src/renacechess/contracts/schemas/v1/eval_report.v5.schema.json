{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evaluation Report v5",
  "description": "Schema for evaluation report (v5) - extends v4 with outcome metrics (M09)",
  "type": "object",
  "required": [
    "schemaVersion",
    "createdAt",
    "datasetDigest",
    "assemblyConfigHash",
    "policyId",
    "evalConfigHash",
    "overall"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "eval_report.v5",
      "description": "Schema version"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    },
    "datasetDigest": {
      "type": "string",
      "description": "SHA-256 hash from dataset manifest v2 (stable dataset identity)",
      "pattern": "^[a-f0-9]{64}$"
    },
    "assemblyConfigHash": {
      "type": "string",
      "description": "SHA-256 hash from dataset manifest v2 (assembly configuration hash)",
      "pattern": "^[a-f0-9]{64}$"
    },
    "policyId": {
      "type": "string",
      "description": "Policy identifier (e.g., 'baseline.uniform_random')"
    },
    "evalConfigHash": {
      "type": "string",
      "description": "SHA-256 hash of canonical JSON config",
      "pattern": "^[a-f0-9]{64}$"
    },
    "frozenEvalManifestHash": {
      "type": ["string", "null"],
      "description": "SHA-256 hash of frozen eval manifest (if frozen eval was used)",
      "pattern": "^[a-f0-9]{64}$"
    },
    "overall": {
      "$ref": "#/definitions/conditionedMetrics",
      "description": "Overall metrics (all records)"
    },
    "bySkillBucketId": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/conditionedMetrics"
      },
      "description": "Metrics stratified by M06 skill bucket ID"
    },
    "byTimeControlClass": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/conditionedMetrics"
      },
      "description": "Metrics stratified by time control class"
    },
    "byTimePressureBucket": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/conditionedMetrics"
      },
      "description": "Metrics stratified by time pressure bucket"
    },
    "outcomeMetrics": {
      "type": ["object", "null"],
      "description": "Outcome head metrics (present only if outcome head was used)",
      "$ref": "#/definitions/outcomeMetrics"
    },
    "outcomeMetricsBySkill": {
      "type": ["object", "null"],
      "description": "Outcome metrics stratified by skill bucket (present only if outcome head was used)",
      "additionalProperties": {
        "$ref": "#/definitions/outcomeMetrics"
      }
    },
    "outcomeMetricsByTimeControl": {
      "type": ["object", "null"],
      "description": "Outcome metrics stratified by time control class (present only if outcome head was used)",
      "additionalProperties": {
        "$ref": "#/definitions/outcomeMetrics"
      }
    },
    "outcomeMetricsByTimePressure": {
      "type": ["object", "null"],
      "description": "Outcome metrics stratified by time pressure bucket (present only if outcome head was used)",
      "additionalProperties": {
        "$ref": "#/definitions/outcomeMetrics"
      }
    }
  },
  "definitions": {
    "conditionedMetrics": {
      "type": "object",
      "required": [
        "totalRecords",
        "labeledRecords",
        "recordsWithPolicy"
      ],
      "properties": {
        "totalRecords": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of records in this stratum"
        },
        "labeledRecords": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of records with chosenMove label"
        },
        "recordsWithPolicy": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of records with policy output"
        },
        "accuracy": {
          "type": ["object", "null"],
          "description": "Accuracy metrics (computed only over labeled records, optional)",
          "properties": {
            "top1": {
              "type": "string",
              "pattern": "^\\d+\\.\\d{6}$",
              "description": "Top-1 accuracy (6 decimal places, fixed-format string)"
            },
            "topK": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "pattern": "^\\d+\\.\\d{6}$"
              },
              "description": "Top-K accuracy metrics (keyed by K as string, e.g., '3', '5', '10')"
            },
            "coverage": {
              "type": "string",
              "pattern": "^\\d+\\.\\d{6}$",
              "description": "Coverage (labeled / total records, 6 decimal places)"
            }
          },
          "required": ["top1", "coverage"]
        },
        "distribution": {
          "type": ["object", "null"],
          "description": "Distribution metrics (computed over all records with policy)",
          "properties": {
            "entropy": {
              "type": "object",
              "properties": {
                "mean": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                },
                "median": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                },
                "stddev": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                }
              },
              "required": ["mean"]
            },
            "topGap": {
              "type": "object",
              "properties": {
                "mean": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                },
                "median": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                },
                "stddev": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                }
              },
              "required": ["mean"]
            },
            "legalMovesCount": {
              "type": "object",
              "properties": {
                "mean": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                },
                "median": {
                  "type": "string",
                  "pattern": "^\\d+\\.\\d{6}$"
                }
              },
              "required": ["mean"]
            }
          }
        },
        "validity": {
          "type": ["object", "null"],
          "description": "Policy validity metrics (from v1/v2 reports)",
          "properties": {
            "illegalRate": {
              "type": "string",
              "pattern": "^\\d+\\.\\d{6}$"
            },
            "topKLegalCoverage": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "pattern": "^\\d+\\.\\d{6}$"
              }
            },
            "policyEntropy": {
              "type": "string",
              "pattern": "^\\d+\\.\\d{6}$"
            },
            "uniqueMovesEmitted": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "hdi": {
          "type": ["object", "null"],
          "description": "Human Difficulty Index (HDI) metrics (M07, optional for v3 compatibility)",
          "properties": {
            "value": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "description": "Human Difficulty Index scalar value [0.0, 1.0]"
            },
            "specVersion": {
              "type": "integer",
              "const": 1,
              "description": "HDI specification version (1 for M07)"
            },
            "components": {
              "type": "object",
              "required": [
                "entropy",
                "topGapInverted",
                "legalMovePressure",
                "outcomeSensitivity"
              ],
              "properties": {
                "entropy": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Normalized policy entropy component [0.0, 1.0]"
                },
                "topGapInverted": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Inverted normalized top gap (higher = more ambiguous) [0.0, 1.0]"
                },
                "legalMovePressure": {
                  "type": "number",
                  "minimum": 0.0,
                  "maximum": 1.0,
                  "description": "Normalized legal move pressure [0.0, 1.0]"
                },
                "outcomeSensitivity": {
                  "type": "object",
                  "required": [
                    "value",
                    "source",
                    "note"
                  ],
                  "properties": {
                    "value": {
                      "type": "number",
                      "minimum": 0.0,
                      "maximum": 1.0,
                      "description": "Outcome sensitivity value (normalized to [0.0, 1.0])"
                    },
                    "source": {
                      "type": "string",
                      "enum": ["proxy", "outcome_head"],
                      "description": "Source of outcome sensitivity (proxy or outcome_head)"
                    },
                    "note": {
                      "type": "string",
                      "description": "Note about the source (e.g., 'entropy * (1 - topGap); replaced when outcome head exists')"
                    }
                  }
                }
              }
            }
          },
          "required": [
            "value",
            "specVersion",
            "components"
          ]
        }
      }
    },
    "outcomeMetrics": {
      "type": "object",
      "required": [
        "totalPredictions"
      ],
      "properties": {
        "totalPredictions": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of outcome predictions"
        },
        "crossEntropy": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "description": "Average cross-entropy (log loss) - lower is better"
        },
        "brierScore": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "description": "Average Brier score - lower is better"
        },
        "ece": {
          "type": ["number", "null"],
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Expected Calibration Error (10-bin equal-width) - lower is better"
        }
      }
    }
  }
}

