{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LLM Context Bridge Payload",
  "description": "Schema for LLM Context Bridge payload (v1)",
  "type": "object",
  "required": [
    "position",
    "conditioning",
    "policy",
    "humanWDL",
    "hdi",
    "narrativeSeeds",
    "meta"
  ],
  "properties": {
    "position": {
      "type": "object",
      "required": ["fen", "sideToMove", "legalMoves"],
      "properties": {
        "fen": {
          "type": "string",
          "description": "FEN string representation of the position"
        },
        "sideToMove": {
          "type": "string",
          "enum": ["white", "black"],
          "description": "Side to move"
        },
        "legalMoves": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of legal moves in UCI format"
        }
      }
    },
    "conditioning": {
      "type": "object",
      "required": ["skillBucket", "timePressureBucket"],
      "properties": {
        "skillBucket": {
          "type": "string",
          "description": "Skill bucket identifier (e.g., '1200-1400')"
        },
        "timePressureBucket": {
          "type": "string",
          "enum": ["NORMAL", "LOW", "TROUBLE"],
          "description": "Time pressure bucket"
        },
        "timeControlClass": {
          "type": ["string", "null"],
          "enum": ["blitz", "rapid", "classical"],
          "description": "Time control class (optional)"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["topMoves", "entropy", "topGap"],
      "properties": {
        "topMoves": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["uci", "p"],
            "properties": {
              "uci": {
                "type": "string",
                "description": "Move in UCI format"
              },
              "san": {
                "type": ["string", "null"],
                "description": "Move in SAN format (optional)"
              },
              "p": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Probability of this move"
              }
            }
          }
        },
        "entropy": {
          "type": "number",
          "minimum": 0,
          "description": "Policy entropy (Shannon entropy)"
        },
        "topGap": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Gap between top move probability and second move"
        }
      }
    },
    "humanWDL": {
      "type": "object",
      "required": ["pre", "postByMove"],
      "properties": {
        "pre": {
          "type": "object",
          "required": ["w", "d", "l"],
          "properties": {
            "w": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Win probability"
            },
            "d": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Draw probability"
            },
            "l": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Loss probability"
            }
          }
        },
        "postByMove": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["w", "d", "l"],
            "properties": {
              "w": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "d": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "l": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          },
          "description": "WDL probabilities after each candidate move (keyed by UCI)"
        }
      }
    },
    "hdi": {
      "type": "object",
      "required": ["value", "components"],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "description": "Human Difficulty Index (scalar)"
        },
        "components": {
          "type": "object",
          "required": ["entropy", "topGap", "wdlSensitivity"],
          "properties": {
            "entropy": {
              "type": "number",
              "minimum": 0,
              "description": "Policy entropy component"
            },
            "topGap": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Top gap component"
            },
            "wdlSensitivity": {
              "type": "number",
              "minimum": 0,
              "description": "WDL sensitivity component"
            }
          }
        }
      }
    },
    "narrativeSeeds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "facts"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["trap-risk", "confusing", "time-sensitive", "critical"],
            "description": "Narrative seed type"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high"],
            "description": "Severity level"
          },
          "facts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of factual statements"
          }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["schemaVersion", "generatedAt", "inputHash"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "v1",
          "description": "Schema version"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of generation"
        },
        "inputHash": {
          "type": "string",
          "description": "Hash of input data (PGN + position)"
        }
      }
    }
  }
}

