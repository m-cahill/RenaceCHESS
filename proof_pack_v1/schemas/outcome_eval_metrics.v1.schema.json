{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://renacechess.dev/schemas/v1/outcome_eval_metrics.v1.schema.json",
  "title": "OutcomeEvalMetricsV1",
  "description": "Outcome head evaluation metrics artifact (M32). Measures W/D/L prediction quality.",
  "type": "object",
  "required": [
    "version",
    "generatedAt",
    "sourceManifestHash",
    "modelId",
    "accuracy",
    "brierScore",
    "nll",
    "ece",
    "samplesEvaluated",
    "determinismHash"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version identifier"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of evaluation"
    },
    "sourceManifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of frozen eval manifest used"
    },
    "modelId": {
      "type": "string",
      "description": "Model identifier (e.g., 'trained', 'baseline-1337')"
    },
    "checkpointHash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of checkpoint file (null for baseline)"
    },
    "accuracy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Accuracy of predicted outcome class (argmax)"
    },
    "brierScore": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Brier score for W/D/L probabilities (lower is better)"
    },
    "nll": {
      "type": "number",
      "minimum": 0.0,
      "description": "Negative log-likelihood of true outcome"
    },
    "ece": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Expected Calibration Error (lower is better)"
    },
    "winAccuracy": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Accuracy on win-labeled positions"
    },
    "drawAccuracy": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Accuracy on draw-labeled positions"
    },
    "lossAccuracy": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Accuracy on loss-labeled positions"
    },
    "samplesEvaluated": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of samples evaluated"
    },
    "bySkillBucket": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/SkillBucketOutcomeMetricsV1"
      },
      "description": "Per-skill bucket breakdown"
    },
    "determinismHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash for determinism verification"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SkillBucketOutcomeMetricsV1": {
      "type": "object",
      "required": ["skillBucket", "samples", "accuracy", "brierScore", "nll", "ece"],
      "properties": {
        "skillBucket": {
          "type": "string",
          "enum": [
            "lt_800",
            "800_999",
            "1000_1199",
            "1200_1399",
            "1400_1599",
            "1600_1799",
            "gte_1800",
            "unknown"
          ],
          "description": "Skill bucket ID"
        },
        "samples": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of samples in this bucket"
        },
        "accuracy": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "brierScore": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "nll": {
          "type": "number",
          "minimum": 0.0
        },
        "ece": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      },
      "additionalProperties": false
    }
  }
}

